# Copy this file to config.env on the robot workstation and edit the values.

HF_USER=your_hf_username
DATASET_NAME=so101_cube_pick
DATASET_REPO_ID=your_hf_username/so101_cube_pick
DATASET_ROOT=cache/datasets/so101_cube_pick
TASK_DESCRIPTION="Pick up the cube"

ROBOT_TYPE=so101_follower
ROBOT_PORT=/dev/ttyACM0
ROBOT_ID=so101_follower

TELEOP_TYPE=so101_leader
TELEOP_PORT=/dev/ttyACM1
TELEOP_ID=so101_leader

CONTROL_FPS=30
DISPLAY_DATA=true
DISPLAY_COMPRESSED_IMAGES=true

# Camera layout:
# - overhead: Intel RealSense D455
# - side: Intel RealSense D435i
# - wrist: Intel RealSense D405
# Keep all camera resolutions equal for ACT training.
OVERHEAD_REALSENSE_WIDTH=640
OVERHEAD_REALSENSE_HEIGHT=480
OVERHEAD_REALSENSE_FPS=30
OVERHEAD_REALSENSE_WARMUP_S=10
SIDE_REALSENSE_WIDTH=640
SIDE_REALSENSE_HEIGHT=480
SIDE_REALSENSE_FPS=30
SIDE_REALSENSE_WARMUP_S=10
WRIST_REALSENSE_WIDTH=640
WRIST_REALSENSE_HEIGHT=480
WRIST_REALSENSE_FPS=30
WRIST_REALSENSE_WARMUP_S=10
D455_SERIAL_OR_NAME=replace_with_d455_serial
D435I_SERIAL_OR_NAME=replace_with_d435i_serial
D405_SERIAL_OR_NAME=replace_with_d405_serial

NUM_EPISODES=50
RESET_TIME_S=10
EPISODE_TIME_S=30
PUSH_TO_HUB=false
RESUME_RECORDING=false
DATASET_STREAMING_ENCODING=false
DATASET_ENCODER_QUEUE_MAXSIZE=120
DATASET_ENCODER_THREADS=1
DATASET_CAMERA_VCODEC=h264
DATASET_CAMERA_CRF=30
DATASET_IMAGE_WRITER_PROCESSES=1
DATASET_IMAGE_WRITER_THREADS_PER_CAMERA=4

TRAIN_OUTPUT_DIR=outputs/train/so101_cube_act
TRAIN_STEPS=30000
TRAIN_BATCH_SIZE=64
TRAIN_NUM_WORKERS=8
TRAIN_PREFETCH_FACTOR=4
TRAIN_SAVE_FREQ=10000
TRAIN_POLICY_USE_AMP=true
TRAIN_DATASET_RETURN_UINT8=true

# For rollout, point to a local checkpoint directory or a Hub repo.
# Typical local path: outputs/train/so101_cube_act/checkpoints/last/pretrained_model
POLICY_PATH=outputs/train/so101_cube_act/checkpoints/last/pretrained_model
POLICY_TEMPORAL_ENSEMBLE_COEFF=0.03
POLICY_N_ACTION_STEPS=1
ROLLOUT_DURATION_S=7
ROLLOUT_LOOP=true
ROLLOUT_RETURN_ON_RESET=true
